generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
  OPERATOR
}

enum BookingStatus {
  PENDING
  PAYMENT_PENDING
  CONFIRMED
  ASSIGNED
  IN_SERVICE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ServiceType {
  TOUR
  CAR
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  fullName     String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(CUSTOMER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
}

model Tour {
  id                 String             @id @default(cuid())
  slug               String             @unique
  title              String
  subtitle           String?
  description        String
  duration           String
  groupSize          String
  basePrice          Decimal            @db.Decimal(10, 2)
  currency           String             @default("USD")
  category           String
  difficulty         String?
  meetingPoint       String?
  cancellationPolicy String?
  highlights         String[]
  inclusions         String[]
  exclusions         String[]
  coverImage         String?
  mapEmbed           String?
  mapImage           String?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  media              TourMedia[]
  itinerary          TourItineraryItem[]
  bookings           BookingItem[]
  availability       AvailabilitySlot[]
}

model TourMedia {
  id        String   @id @default(cuid())
  tourId    String
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  type      String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model TourItineraryItem {
  id          String   @id @default(cuid())
  tourId       String
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  dayNumber   Int
  title       String
  description String
  mediaUrl    String?
}

model Car {
  id                   String      @id @default(cuid())
  slug                 String      @unique
  name                 String
  category             String
  description          String
  seats                Int
  luggage              Int
  pricePerDay          Decimal     @db.Decimal(10, 2)
  priceAirportTransfer Decimal     @db.Decimal(10, 2)
  currency             String      @default("USD")
  features             String[]
  coverImage           String?
  galleryImages        String[]
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  bookings             BookingItem[]
  availability         AvailabilitySlot[]
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  country   String?
  text      String
  rating    Int
  relatedTo String?
  createdAt DateTime @default(now())
}

model Booking {
  id              String         @id @default(cuid())
  reference       String         @unique
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  status          BookingStatus  @default(PENDING)
  travelerName    String
  travelerEmail   String
  travelerPhone   String?
  notes           String?
  startDate       DateTime
  endDate         DateTime?
  guestCount      Int            @default(1)
  baseAmount      Decimal        @db.Decimal(10, 2)
  totalAmount     Decimal        @db.Decimal(10, 2)
  currency        String         @default("USD")
  promoCode       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           BookingItem[]
  payments        Payment[]
}

model BookingItem {
  id          String      @id @default(cuid())
  bookingId   String
  booking     Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceType ServiceType
  tourId      String?
  tour        Tour?       @relation(fields: [tourId], references: [id], onDelete: SetNull)
  carId       String?
  car         Car?        @relation(fields: [carId], references: [id], onDelete: SetNull)
  quantity    Int         @default(1)
  unitPrice   Decimal     @db.Decimal(10, 2)
  totalPrice  Decimal     @db.Decimal(10, 2)
}

model AvailabilitySlot {
  id          String      @id @default(cuid())
  serviceType ServiceType
  tourId      String?
  tour        Tour?       @relation(fields: [tourId], references: [id], onDelete: Cascade)
  carId       String?
  car         Car?        @relation(fields: [carId], references: [id], onDelete: Cascade)
  slotDate    DateTime
  capacity    Int
  bookedCount Int         @default(0)

  @@index([slotDate])
}

model PricingRule {
  id              String    @id @default(cuid())
  name            String
  serviceType     ServiceType
  isActive        Boolean   @default(true)
  startDate       DateTime?
  endDate         DateTime?
  dayOfWeek       Int?
  percentageDelta Decimal   @db.Decimal(5, 2)
  fixedDelta      Decimal?  @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())
}

model Addon {
  id          String      @id @default(cuid())
  name        String
  serviceType ServiceType
  price       Decimal     @db.Decimal(10, 2)
  isActive    Boolean     @default(true)
}

model PromoCode {
  id               String    @id @default(cuid())
  code             String    @unique
  percentageOff    Decimal?  @db.Decimal(5, 2)
  fixedAmountOff   Decimal?  @db.Decimal(10, 2)
  maxUses          Int?
  usedCount        Int       @default(0)
  expiresAt        DateTime?
  isActive         Boolean   @default(true)
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider          String        @default("flutterwave")
  txRef             String        @unique
  transactionId     String?
  customerEmail     String
  amount            Decimal       @db.Decimal(10, 2)
  currency          String
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  rawPayload        Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ContactInquiry {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}
